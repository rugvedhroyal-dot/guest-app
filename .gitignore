# .gitignore for Guest React app

# ─── Secrets — NEVER commit these ────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
build/
dist/

# ─── Misc ─────────────────────────────────────────────────────────────────────
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.cache
